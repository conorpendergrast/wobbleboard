# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Intercom Configuration
# INTERCOM_REGION: Region of your Intercom workspace. One of: us, eu, au.
# Defaults to us if unset. Set this to match your workspace or sync calls
# will fail with "Resource Not Found".
INTERCOM_REGION=us

# INTERCOM_ACCESS_TOKEN: API token for Intercom API access (server-side only)
# Get from: Intercom Admin > Settings > Integrations > Developers
INTERCOM_ACCESS_TOKEN=your-intercom-access-token

# INTERCOM_CONNECTOR_API_KEY: Bearer token for external integration requests
# Used by /api/intercom/subscriptions endpoint
# This should be a secure random token shared with external systems
INTERCOM_CONNECTOR_API_KEY=your-connector-api-key

# INTERCOM_WORKSPACE_ID: Your Intercom workspace ID (a.k.a. app_id).
# Used by `npm run cleanup:intercom` to construct clickable dashboard URLs
# for any companies Intercom won't delete via API (manual UI cleanup needed).
# How to find it: open any page in your Intercom dashboard and copy the
# segment after `/a/apps/` in the URL — e.g. in
# `https://app.intercom.com/a/apps/uq9fbojb/inbox`, the workspace ID is
# `uq9fbojb`. Alternatively, it's the `app.id_code` field returned by
# `GET /me`. Set this in BOTH `.env.local` and your Vercel project env vars.
INTERCOM_WORKSPACE_ID=your-workspace-id
