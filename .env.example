# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Intercom Configuration
# INTERCOM_ACCESS_TOKEN: API token for Intercom API access (server-side only)
# Get from: Intercom Admin > Settings > Integrations > Developers
INTERCOM_ACCESS_TOKEN=your-intercom-access-token

# INTERCOM_CONNECTOR_API_KEY: Bearer token for external integration requests
# Used by /api/intercom/subscriptions endpoint
# This should be a secure random token shared with external systems
INTERCOM_CONNECTOR_API_KEY=your-connector-api-key
